{
  "name": "@api-feedback/sdk",
  "version": "0.1.0",
  "description": "Framework-agnostic API error feedback SDK with business-defined feedback triggers.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "vite examples/vanilla --host 0.0.0.0",
    "build:example": "vite build examples/vanilla --outDir ../../dist-example --emptyOutDir",
    "deploy:example": "npm run build:example && npx --yes vercel@latest dist-example",
    "deploy:example:prod": "npm run build:example && npx --yes vercel@latest dist-example --prod"
  },
  "keywords": [
    "feedback",
    "api",
    "sdk",
    "fetch",
    "xhr"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
